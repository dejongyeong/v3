{
  "name": "v3",
  "version": "1.9.1",
  "private": false,
  "author": "DJ (https://github.com/dejongyeong)",
  "license": "MIT",
  "scripts": {
    "dev:next": "next dev --turbopack",
    "dev:spotlight": "spotlight",
    "dev": "run-p dev:*",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier '**/*.{json,yaml}' --write --ignore-path .gitignore",
    "check-types": "tsc --noEmit --pretty",
    "prepare": "husky",
    "commit": "cz",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "@arcjet/next": "^1.0.0-beta.2",
    "@logtail/pino": "^0.5.2",
    "@next/bundle-analyzer": "16.2.6",
    "@sentry/nextjs": "^10.53.1",
    "@spotlightjs/spotlight": "^4.11.4",
    "@t3-oss/env-nextjs": "^0.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.482.0",
    "next": "16.2.6",
    "pino": "^9.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@commitlint/cz-commitlint": "^19.6.1",
    "@commitlint/format": "^19.5.0",
    "@commitlint/prompt": "^19.7.1",
    "@eslint/eslintrc": "^3",
    "@percy/cli": "^1.31.13",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.56.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.7",
    "@vitest/expect": "^3.0.7",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-testing-library": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "inquirer": "^9.3.7",
    "jiti": "^2.4.2",
    "lint-staged": "^15.4.3",
    "npm-run-all": "^4.1.5",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.3",
    "prettier": "3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.0.14",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vitest-fail-on-console": "^0.10.1"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
